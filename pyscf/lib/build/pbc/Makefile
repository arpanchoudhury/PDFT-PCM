	cd /Users/arpan/Library/pyscf/pyscf/lib/build && $(MAKE) $(MAKESILENT) -f pbc/CMakeFiles/pbc.dir/build.make pbc/CMakeFiles/pbc.dir/transform_mo.c.s
.PHONY : transform_mo.c.s

